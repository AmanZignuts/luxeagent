# ============================================================
# Vestira Concierge — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit real keys or secrets to git.

# --- Supabase Configuration ---
# Local CLI Default: URL is http://127.0.0.1:54321
# Hosted: Get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Google Generative AI (Gemini) ---
# Required for Vestira Concierge chat, vision ingest, and embedding generation.
# Get your free key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Alternative key name supported by the Gemini SDK:
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
