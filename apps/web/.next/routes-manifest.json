{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/pdp/[itemId]",
      "regex": "^/pdp/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPitemId": "nxtPitemId"
      },
      "namedRegex": "^/pdp/(?<nxtPitemId>[^/]+?)(?:/)?$",
      "prefetchSegmentDataRoutes": [
        {
          "destination": "/pdp/[itemId].segments/!KGN1c3RvbWVyKQ/pdp/$d$itemId$segment",
          "source": "^/pdp/(?<nxtPitemId>[^/]+?)\\.segments/!KGN1c3RvbWVyKQ/pdp/\\$d\\$itemId(?<segment>/__PAGE__\\.segment\\.rsc|\\.segment\\.rsc)(?:/)?$",
          "routeKeys": {
            "nxtPitemId": "nxtPitemId"
          }
        }
      ]
    }
  ],
